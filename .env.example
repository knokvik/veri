# ──── Supabase Auth ────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ──── Blockchain (Hardhat / Next.js) ────
NEXT_PUBLIC_POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology
NEXT_PUBLIC_VERICREDIT_CONTRACT_ADDRESS=0xYourDeployedContractAddressHere
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here
PRIVATE_KEY=your_wallet_private_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# ──── IPFS Integration ────
NFT_STORAGE_API_KEY=your_nft_storage_api_key_here

# ──── AI / ML Validations (FastAPI) ────
GEE_SERVICE_ACCOUNT_EMAIL=your_gee_service_account@appspot.gserviceaccount.com
GEE_PRIVATE_KEY_JSON_PATH=./google_earth_engine_keys.json

# ──── CCTS Configuration ────
BEE_CCTS_API_ENDPOINT=https://ccts.bee.gov.in/api/v1/mock

# ──── Google AI Keys ────
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here
